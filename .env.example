PORT=3000

# Turso (libSQL)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# JWT
JWT_SECRET=

# Resend (email notifications)
RESEND_API_KEY=
EMAIL_FROM=Teamly <noreply@teamly.app>

# App
APP_URL=http://localhost:3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Demo mode — set DEMO_MODE=true to run an isolated sandbox on a local SQLite
# file (no Turso needed). Used for the public preview deploy. Leave unset for
# real deployments. DEMO_URL is used by the REAL deploy so /preview can forward
# visitors to your demo instance.
DEMO_MODE=
DEMO_URL=
